---
import AnimatedCounter from './AnimatedCounter.jsx';
const { lang, t } = Astro.props;

function highlightBraces(text) {
  return text.split(/(\{.*?\})/g);
}
---

<section class="section about" id="about">
  <div class="container">
    <h2 class="section-title">
      <span class="title-decoration">//</span> {t('about.title')}
    </h2>

    <div class="about-grid">
      <div class="about-text">

        <p class="about-bio">
          {highlightBraces(t('about.bio1')).map((part) =>
            part.startsWith('{') && part.endsWith('}')
              ? <span class="highlight">{part.slice(1, -1)}</span>
              : part
          )}
        </p>

        <p class="about-bio">
          {highlightBraces(t('about.bio2')).map((part) =>
            part.startsWith('{') && part.endsWith('}')
              ? <span class="highlight">{part.slice(1, -1)}</span>
              : part
          )}
        </p>

      </div>

      <div class="about-stats">
        <div class="stat-card">
          <AnimatedCounter target={8} client:visible />
          <span class="stat-suffix">+</span>
          <span class="stat-label">{t('about.stats.projects')}</span>
        </div>

        <div class="stat-card">
          <AnimatedCounter target={10} client:visible />
          <span class="stat-suffix">+</span>
          <span class="stat-label">{t('about.stats.technologies')}</span>
        </div>

        <div class="stat-card">
          <AnimatedCounter target={3} client:visible />
          <span class="stat-suffix">+</span>
          <span class="stat-label">{t('about.stats.yearsCoding')}</span>
        </div>
      </div>
    </div>
  </div>
</section>