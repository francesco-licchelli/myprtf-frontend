---
const { lang, t } = Astro.props;

const skills = {
  Backend: [
    { name: 'Java', rating: 5 },
    { name: 'Spring Boot', rating: 5 },
    { name: 'Python', rating: 4 },
    { name: 'Django', rating: 3 },
  ],
  Frontend: [
    { name: 'React', rating: 4 },
    { name: 'HTML/CSS', rating: 4 },
    { name: 'JavaScript', rating: 4 },
    { name: 'Vue.js', rating: 3 },
  ],
  'Systems & DevOps': [
    { name: 'GNU/Linux', rating: 4 },
    { name: 'C', rating: 4 },
    { name: 'Bash', rating: 4 },
    { name: 'Docker', rating: 3 },
    { name: 'Jenkins', rating: 3 },
    { name: 'Ansible', rating: 2 },
  ],
  'Tools & More': [
    { name: 'Git', rating: 5 },
    { name: 'JUnit 6', rating: 4 },
    { name: 'Mockito', rating: 4 },
    { name: 'ServiceNow', rating: 3 },
    { name: 'Kotlin', rating: 3 },
  ],
  Databases: [
    { name: 'MongoDB', rating: 4 },
    { name: 'MySQL', rating: 3 },
  ],
};
---

<section class="section skills" id="skills">
  <div class="container">
    <h2 class="section-title">
      <span class="title-decoration">//</span> {t('skills.title')}
    </h2>
    <div class="skills-list">
      {Object.entries(skills).map(([category, items]) => (
        <div class="skills-category">
          <h3 class="skills-category-title">{category}</h3>
          {items.map((skill) => (
            <div class="skills-row">
              <span class="skills-name">{skill.name}</span>
              <span class="skills-dots">
                {Array.from({ length: 5 }, (_, i) => (
                  <span class={`skills-dot${i < skill.rating ? ' filled' : ''}`} />
                ))}
              </span>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
